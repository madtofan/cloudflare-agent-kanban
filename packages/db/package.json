{
  "name": "@cloudflare-agent-kanban/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "dev": "export LOCAL_DB_PATH=$(find ../../.alchemy -name \"*.sqlite\" | head -n 1) && drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@cloudflare-agent-kanban/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare-agent-kanban/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
